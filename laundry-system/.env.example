# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=lavanderpro
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lavanderpro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Adminer (DB UI)
ADMINER_PORT=8081

# API
PORT=4000
CORS_ORIGINS=http://localhost:3000

# JWT — REPLACE in production with 32+ bytes random
JWT_SECRET=change-me-with-32-bytes-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=60d

# MinIO / S3 (object storage for logos)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=lavanderpro-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_HOST=
S3_PRESIGN_EXPIRES_SECONDS=300