# ═══════════════════════════════════════════════════════════════════
# LavanderPro — Variables de entorno para PRODUCCIÓN (Coolify)
# ═══════════════════════════════════════════════════════════════════
# En Coolify estas variables se configuran en la UI del recurso (más seguro
# que commitearlas). Esta plantilla sirve de checklist.
#
# Hay 3 RECURSOS en Coolify, cada uno con sus propias variables:
#   1. PostgreSQL (Coolify-managed)        — DATABASE_URL via Coolify
#   2. Redis (Coolify-managed)              — REDIS_URL via Coolify
#   3. API (Docker Compose)                 — todas las vars de abajo
#   4. Web (Static Site)                    — solo NEXT_PUBLIC_API_URL

# ───────────────────────────────────────────────────────────────
# RECURSO 1: API (docker-compose.coolify.yml)
# ───────────────────────────────────────────────────────────────

# ─── PostgreSQL (Coolify-managed o externo) ───
# Hostname dentro de la red de Coolify. Coolify expone servicios al nombre
# del recurso. Si tu Postgres se llama "postgres" en Coolify, este valor
# es "postgres". Si tiene ID, suele ser "postgres-<id>".
# Verificar en: Coolify → Resources → postgres → "Internal Hostname"
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lavanderpro
POSTGRES_PASSWORD=CHANGE_ME_random_32_bytes
POSTGRES_DB=lavanderpro

# ─── Redis (Coolify-managed o externo) ───
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ───
# CRÍTICO: 32+ bytes random. Cambiar en cada entorno.
# Generar: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_32_bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=60d

# ─── CORS ───
# Dominios desde los que el frontend puede llamar la API.
# Separar comas, sin espacios, incluir esquema (https://).
# Ejemplo: tu dominio público principal + dominio del dashboard
CORS_ORIGINS=https://lavander.tu-dominio.com,https://www.lavander.tu-dominio.com

# ───────────────────────────────────────────────────────────────
# RECURSO 2: Web (Coolify Static Site — sin contenedor)
# ───────────────────────────────────────────────────────────────

# Esta variable se inyecta al BUILD del frontend (queda horneada en el JS).
# Cambiarla requiere reconstruir el sitio.
# Debe apuntar al dominio público de la API.
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com/api

# ───────────────────────────────────────────────────────────────
# NO necesarios en Coolify-managed:
# ───────────────────────────────────────────────────────────────
# DATABASE_URL / REDIS_URL: Coolify los inyecta automáticamente en sus
# servicios de DB. Solo aplican si usas DBs externas (no Coolify).
#
# FRONTEND_PORT, API_PORT: Coolify maneja el routing via Traefik.
#
# VOLUMEN_PATHS: Coolify monta los volúmenes automáticamente.