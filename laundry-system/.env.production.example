# ═══════════════════════════════════════════════════════════════════
# LavanderPro — Variables de entorno para PRODUCCIÓN (Coolify)
# ═══════════════════════════════════════════════════════════════════
# Copiar a `.env.production` y completar ANTES de hacer deploy.
# En Coolify, las mismas variables se configuran en la UI del recurso
# (pestaña "Environment Variables") y son más seguras que commiteadas.

# ─── PostgreSQL ───
# Generar contraseña fuerte: openssl rand -hex 32
POSTGRES_DB=lavanderpro
POSTGRES_USER=lavanderpro
POSTGRES_PASSWORD=CHANGE_ME_random_32_bytes_here

# ─── JWT ───
# CRÍTICO: cambiar este secret en producción. 32+ bytes random.
# Generar: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_32_bytes_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=60d

# ─── Frontend ───
# URL público de la API, exactamente como Coolify la expone.
# Si tu dominio es api.lavanderpro.com → NEXT_PUBLIC_API_URL=https://api.lavanderpro.com/api
# Si compartes dominio con path /api → NEXT_PUBLIC_API_URL=https://lavanderpro.com/api
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com/api

# ─── Backend CORS ───
# Dominios desde los que el frontend puede llamar la API.
# Separar con comas, sin espacios. Incluir esquema (https://).
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ─── Opcionales ───
# Si Coolify expone Postgres/Redis en otra red, ajustar:
# POSTGRES_HOST=postgres
# REDIS_HOST=redis